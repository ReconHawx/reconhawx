### Wildcard Detection

Uses `dnsx_wrapper.is_wildcard()` to detect wildcard DNS responses:

```python
def _resolve_domain_with_wildcard_detection(self, domain):
    # Basic DNS resolution
    ip = socket.gethostbyname(domain)
    
    # Wildcard detection
    is_wild, wild_types = await is_wildcard(domain)
    
    return {
        "has_records": True,
        "a_records": [ip],
        "is_wildcard": is_wild,        # True if wildcard
        "wildcard_types": wild_types   # ["A", "AAAA", etc.]
    }
```

### Subdomain Discovery

```python
def _find_subdomains(self, domain):
    cmd = ['subfinder', '-d', domain, '-silent', '-o', '/dev/stdout']
    result = subprocess.run(cmd, capture_output=True, text=True, timeout=300)
    
    subdomains = []
    for line in result.stdout.strip().split('\n'):
        subdomain = line.strip()
        if subdomain and subdomain != domain:
            subdomains.append(subdomain)
    
    return subdomains
```

