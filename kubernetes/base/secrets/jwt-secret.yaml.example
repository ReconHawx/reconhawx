# JWT signing keys for the API. Copy to jwt-secret.yaml and replace values:
#
#   cp jwt-secret.yaml.example jwt-secret.yaml
#   # Generate base64-encoded random keys:
#   echo -n "$(openssl rand -hex 32)" | base64 -w0
#
# Replace both data values below before applying.
apiVersion: v1
kind: Secret
metadata:
  name: jwt-secret
type: Opaque
data:
  jwt-secret-key: REPLACE_WITH_BASE64_ENCODED_KEY
  refresh-secret-key: REPLACE_WITH_BASE64_ENCODED_KEY
