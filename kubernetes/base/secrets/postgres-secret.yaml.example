# PostgreSQL credentials. Copy to postgres-secret.yaml and set strong values:
#
#   cp postgres-secret.yaml.example postgres-secret.yaml
#   # Encode your credentials:
#   echo -n 'mystrongpassword' | base64 -w0
#
# Replace both data values below before applying.
apiVersion: v1
kind: Secret
metadata:
  name: postgres-secret
type: Opaque
data:
  postgres-root-username: cmVjb25oYXd4 # reconhawx
  postgres-root-password: POSTGRES_PASSWORD_PLACEHOLDER
