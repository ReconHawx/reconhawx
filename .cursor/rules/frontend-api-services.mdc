| `screenshotAPI` | `/assets/screenshot` | `searchScreenshots`, `getById`, `delete` |

## Workflow APIs (`workflows.js`)

### Workflow Definitions (Templates)

```javascript
export const workflowAPI = {
  // Get all saved workflow definitions
  getWorkflows: async (programName = null) => {
    const params = programName ? `?program_name=${encodeURIComponent(programName)}` : '';
    const response = await api.get(`/workflows/definitions${params}`);
    return response.data;
  },

  // Save a new workflow definition
  saveWorkflow: async (workflowData) => {
    const response = await api.post('/workflows/definitions', {
      name: workflowData.workflow_name,
      program_name: workflowData.program_name,
      description: workflowData.description,
      steps: workflowData.steps,
      variables: workflowData.variables || {},
      inputs: workflowData.inputs || {}
    });
    return response.data;
  },

  // Update existing workflow definition
  updateWorkflow: async (workflowId, workflowData) => {
    const response = await api.put(`/workflows/definitions/${workflowId}`, { ... });
    return response.data;
  },

  // Delete workflow definition
  deleteWorkflow: async (workflowId) => {
    const response = await api.delete(`/workflows/definitions/${workflowId}`);
    return response.data;
  }
};
```

### Workflow Executions

```javascript
export const workflowAPI = {
  // Run a workflow
  runWorkflow: async (workflowData) => {
    const response = await api.post('/workflows/run', {
      workflow_name: workflowData.workflow_name,
      program_name: workflowData.program_name,
      steps: workflowData.steps,
      variables: workflowData.variables || {},
      inputs: workflowData.inputs || {},
      workflow_definition_id: workflowData.workflow_definition_id
    });
    return response.data;
  },

  // Get execution status list (paginated)
  getWorkflowStatus: async (page = 1, limit = 25, programName = null, sortField = null, sortOrder = 'desc') => {
    const params = new URLSearchParams({ page, limit });
    if (programName) params.append('program_name', programName);
    if (sortField) params.append('sort_field', sortField);
    const response = await api.get(`/workflows/executions?${params}`);
    return response.data;
  },

  // Get detailed execution status
  getWorkflowStatusDetail: async (workflowId) => {
    const response = await api.get(`/workflows/executions/${workflowId}`);
    return response.data;
  },

  // Stop a running workflow
  stopWorkflow: async (workflowId) => {
    const response = await api.post(`/workflows/executions/${workflowId}/stop`);
    return response.data;
  }
};
```

## Auth APIs (`admin.js`)

```javascript
export const authAPI = {
  login: async (username, password) => {
    const formData = new URLSearchParams();
    formData.append('username', username);
    formData.append('password', password);
    
    const response = await api.post('/auth/login', formData, {
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' }
    });
    return response.data;
  },

  refreshToken: async (refreshToken) => {
    const response = await api.post('/auth/refresh', { refresh_token: refreshToken });
    return response.data;
  },

  logout: async (refreshToken) => {
    const response = await api.post('/auth/logout', { refresh_token: refreshToken });
    return response.data;
  }
};
```

## Response Patterns

### Standard Response Format

```javascript
// Success response
{
  status: 'success',
  data: { ... },           // Single item
  items: [ ... ],          // List items
  total_items: 100,        // For pagination
  page: 1,
  page_size: 25
}

// Error response
{
  status: 'error',
  message: 'Error description'
}
```

### Handling Responses

```javascript
const loadItems = async () => {
  try {
    const response = await assetAPI.search({ program: selectedProgram });
    
    // Handle different response structures
    if (response.items) {
      setItems(response.items);
      setTotalItems(response.total_items || 0);
    } else if (response.data) {
      setItem(response.data);
    } else if (Array.isArray(response)) {
      setItems(response);
    }
  } catch (error) {
    if (error.response?.status === 404) {
      setError('Item not found');
    } else if (error.response?.status === 403) {
      setError('Permission denied');
    } else {
      setError('Failed to load data');
    }
  }
};
```

## Best Practices

1. **Always use typed search endpoints** - Use `searchSubdomains`, `searchURLs`, etc. for filtering
2. **Encode URL parameters** - Use `encodeURIComponent()` for dynamic path segments
3. **Handle all error cases** - Check for 401, 403, 404, and generic errors
4. **Use batch operations** - Use `deleteBatch` for multi-select operations
5. **Pass program filter** - Most search endpoints accept a `program` parameter
6. **Use consistent param naming** - `page`, `page_size`, `sort_by`, `sort_dir`
7. **Check response structure** - Different endpoints may return `data`, `items`, or arrays
