```

## Key Model Patterns

1. **UUID Primary Keys**: Use `UUID(as_uuid=True)` for all primary keys
2. **INET Type**: Use PostgreSQL `INET` type for IP addresses
3. **JSONB**: Use for flexible, schema-less data
4. **ARRAY**: Use for lists (domain_regex, cidr_list, etc.)
5. **Indexes**: Add indexes on frequently queried fields
6. **Timestamps**: Always include `created_at` and `updated_at`
7. **Relationships**: Define bidirectional relationships with `back_populates`
8. **Cascade Delete**: Use `cascade="all, delete-orphan"` for owned relationships

## Relationships

### One-to-Many

```python
class Program(Base):
    __tablename__ = "programs"
    id = Column(UUID(as_uuid=True), primary_key=True, default=uuid.uuid4)
    
    # One program has many subdomains
    subdomains = relationship(
        "Subdomain",
        back_populates="program",
        cascade="all, delete-orphan"  # Delete subdomains when program deleted
    )

class Subdomain(Base):
    __tablename__ = "subdomains"
    id = Column(UUID(as_uuid=True), primary_key=True, default=uuid.uuid4)
    program_id = Column(UUID(as_uuid=True), ForeignKey("programs.id"), nullable=False)
    
    # Many subdomains belong to one program
    program = relationship("Program", back_populates="subdomains")
```

### Many-to-Many with Association Table

```python
class SubdomainIP(Base):
    """Association table"""
    __tablename__ = "subdomain_ips"
    subdomain_id = Column(UUID(as_uuid=True), ForeignKey("subdomains.id"), primary_key=True)
    ip_id = Column(UUID(as_uuid=True), ForeignKey("ips.id"), primary_key=True)

class Subdomain(Base):
    # Many-to-many through association table
    ips = relationship("IP", secondary="subdomain_ips", back_populates="subdomains")

class IP(Base):
    subdomains = relationship("Subdomain", secondary="subdomain_ips", back_populates="ips")
```

## Query Patterns

### Basic Queries

```python
from db import get_db_session
from models.postgres import Subdomain, Program, IP, SubdomainIP

# Get all
async with get_db_session() as db:
    subdomains = db.query(Subdomain).all()

# Get by ID
async with get_db_session() as db:
    subdomain = db.query(Subdomain).filter(Subdomain.id == subdomain_id).first()

# Filter with join
async with get_db_session() as db:
    subdomains = db.query(Subdomain).join(Program).filter(
        Program.name == program_name,
        Subdomain.is_wildcard == True
    ).all()

# Limit and offset
async with get_db_session() as db:
    subdomains = db.query(Subdomain).limit(10).offset(20).all()
```

### Working with INET Type

```python
from sqlalchemy import func

# Query IP addresses
async with get_db_session() as db:
    # Get host part of IP address
    ips = db.query(func.host(IP.ip_address)).all()
    
    # Filter by IP string
    ip = db.query(IP).filter(func.host(IP.ip_address) == "192.168.1.1").first()
    
    # Filter by list of IPs
    ips = db.query(IP).filter(func.host(IP.ip_address).in_(["192.168.1.1", "10.0.0.1"])).all()
```

### Aggregations with Arrays

```python
from sqlalchemy import func

async with get_db_session() as db:
    # Aggregate IPs into array
    ip_array_col = func.array_remove(
        func.array_agg(func.distinct(func.host(IP.ip_address))),
        None,
    )
    
    # Unnest array for distinct values
    values = db.query(func.unnest(Subdomain.wildcard_types)).distinct().all()
    
    # Count distinct
    count = func.count(func.distinct(IP.id))
```

### Joins for IP Relationships

```python
async with get_db_session() as db:
    # Get subdomain with IPs through association table
    ip_addresses = db.query(IP.ip_address).join(
        SubdomainIP, IP.id == SubdomainIP.ip_id
    ).filter(
        SubdomainIP.subdomain_id == subdomain.id
    ).all()
    
    ip_list = [ip[0] for ip in ip_addresses]
```

### Complex Aggregation Query

```python
async with get_db_session() as db:
    # Build query with aggregation columns
    count_ip_col = func.count(func.distinct(IP.id))
    ip_array_col = func.array_remove(
        func.array_agg(func.distinct(func.host(IP.ip_address))),
        None,
    )
    
    base_query = (
        db.query(
            Subdomain.id.label("id"),
            Subdomain.name.label("name"),
            Program.name.label("program_name"),
            ApexDomain.name.label("apex_domain"),
            ip_array_col.label("ip"),
            count_ip_col.label("ip_count"),
        )
        .select_from(Subdomain)
        .join(Program, Program.id == Subdomain.program_id)
        .join(ApexDomain, ApexDomain.id == Subdomain.apex_domain_id)
        .outerjoin(SubdomainIP, Subdomain.id == SubdomainIP.subdomain_id)
        .outerjoin(IP, IP.id == SubdomainIP.ip_id)
        .group_by(Subdomain.id, Subdomain.name, Program.name, ApexDomain.name)
    )
    
    # HAVING clause for filtering on aggregates
    base_query = base_query.having(func.count(func.distinct(IP.id)) > 0)
    
    rows = base_query.all()
```

## Batch Operations

### Bulk Insert

```python
from db import get_batch_db_session

async def bulk_create_subdomains(subdomains: List[Dict[str, Any]]):
    """Bulk insert subdomains"""
    async with get_batch_db_session() as db:
        db.bulk_insert_mappings(Subdomain, subdomains)
        db.commit()
```

### Chunked Bulk Insert

```python
async def bulk_create_subdomains(subdomains: List[Dict[str, Any]], chunk_size: int = 1000):
    """Bulk insert in chunks for very large batches"""
    for i in range(0, len(subdomains), chunk_size):
        chunk = subdomains[i:i + chunk_size]
        async with get_batch_db_session() as db:
            db.bulk_insert_mappings(Subdomain, chunk)
            db.commit()
```

### Bulk Update

```python
async def bulk_update_subdomains(updates: List[Dict[str, Any]]):
    """Bulk update subdomains - each dict must include 'id'"""
    async with get_batch_db_session() as db:
        db.bulk_update_mappings(Subdomain, updates)
        db.commit()
```

## Transaction Management

### Explicit Transactions

```python
async with get_db_session() as db:
    try:
        # Multiple operations
        subdomain1 = Subdomain(name="example1.com", program_id=program_id)
        db.add(subdomain1)
        
        subdomain2 = Subdomain(name="example2.com", program_id=program_id)
        db.add(subdomain2)
        
        # Commit all or none
        db.commit()
    
    except Exception as e:
        db.rollback()
        raise
```

### Flush for Generated IDs

```python
async with get_db_session() as db:
    # Create program and get ID before commit
    program = Program(name="example")
    db.add(program)
    db.flush()  # Get program.id without committing
    
    # Use the ID for related records
    subdomain = Subdomain(name="sub.example.com", program_id=program.id)
    db.add(subdomain)
    
    # Commit everything
    db.commit()
```

## Query Optimization

### Indexes

Add indexes on frequently queried columns:

```python
class Subdomain(Base):
    name = Column(String(255), nullable=False, index=True)
    program_id = Column(UUID(as_uuid=True), ForeignKey("programs.id"), index=True)
    is_wildcard = Column(Boolean, default=False, index=True)
    
    # Composite index for common query patterns
    __table_args__ = (
        Index("idx_subdomain_program_wildcard", "program_id", "is_wildcard"),
    )
```

### Eager Loading

Avoid N+1 queries with eager loading:

```python
from sqlalchemy.orm import joinedload

# Bad: N+1 queries
subdomains = db.query(Subdomain).all()
for subdomain in subdomains:
    print(subdomain.program.name)  # Query for each program

# Good: Single query with join
subdomains = db.query(Subdomain).options(
    joinedload(Subdomain.program)
).all()
for subdomain in subdomains:
    print(subdomain.program.name)  # No additional queries
```

