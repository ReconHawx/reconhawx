## Connection Management

### Automatic Connection

The publisher automatically manages NATS connection:

```python
async def _ensure_connection(self) -> bool:
    """Ensure NATS connection with exponential backoff"""
    if self._connected and self._nc and not self._nc.is_closed:
        return True
    
    async with self._connection_lock:
        # Check again after acquiring lock
        if self._connected and self._nc and not self._nc.is_closed:
            return True
        
        # Exponential backoff
        current_time = time.time()
        if current_time - self._last_connection_attempt < self._connection_retry_delay:
            return False
        
        self._last_connection_attempt = current_time
        
        try:
            self._nc = NATS()
            await self._nc.connect(
                self.nats_url,
                connect_timeout=10,
                reconnect_time_wait=1.0,
                max_reconnect_attempts=5,
                ping_interval=20,
                max_outstanding_pings=5
            )
            
            self._connected = True
            self._connection_retry_delay = 1.0  # Reset on success
            
            # Ensure stream exists
            await self._ensure_stream()
            return True
            
        except Exception as e:
            self._connected = False
            self._connection_retry_delay = min(self._connection_retry_delay * 2, 60.0)
            logger.warning(f"NATS connection failed, retry in {self._connection_retry_delay}s: {e}")
            return False
```

### Stream Configuration

```python
async def _ensure_stream(self) -> bool:
    """Ensure JetStream stream exists"""
    js = self._nc.jetstream()
    
    try:
        await js.stream_info(self.stream)
        return True
    except Exception:
        # Create stream
        stream_config = StreamConfig(
            name=self.stream,
            subjects=["events.>"],  # Match all events.* subjects
            retention=RetentionPolicy.WORK_QUEUE,
            max_age=86400,              # 24 hours
            max_msgs=1000000,           # 1M messages
            max_bytes=1024*1024*1024,   # 1GB
        )
        await js.add_stream(stream_config)
        return True
```

## Error Handling

### Graceful Degradation

The publisher handles errors gracefully:

```python
# If NATS is unavailable:
# 1. Events are logged as warnings
# 2. Application continues normally
# 3. Connection retried with exponential backoff
# 4. Events queued until connection restored
```

### Retry Logic

```python
async def _publish_single_event(self, subject: str, payload: Dict) -> bool:
    """Publish with retry logic"""
    if not await self._ensure_connection():
        return False
    
    max_retries = 3
    retry_delay = 0.1
    
    for attempt in range(max_retries):
        try:
            js = self._nc.jetstream()
            data = json.dumps(payload).encode("utf-8")
            ack = await js.publish(subject, data, timeout=10)
            return True
            
        except Exception as e:
            if attempt < max_retries - 1:
                logger.warning(f"Publish attempt {attempt + 1} failed: {e}")
                await asyncio.sleep(retry_delay)
                retry_delay *= 2  # Exponential backoff
                
                # Reconnect if connection issues
                if "connection" in str(e).lower():
                    self._connected = False
                    await self._ensure_connection()
            else:
                logger.error(f"Publish failed after {max_retries} attempts: {e}")
                return False
    
    return False
```

## Flushing and Shutdown

### Manual Flush

```python
# Force publish all pending batches
await publisher.flush_batches()
```

### Graceful Shutdown

```python
async def shutdown(self):
    """Graceful shutdown"""
    # Stop batch processor
    if self._batch_processor_task and not self._batch_processor_task.done():
        self._batch_processor_task.cancel()
        try:
            await self._batch_processor_task
        except asyncio.CancelledError:
            pass
    
    # Flush remaining batches
    await self.flush_batches()
    
    # Close NATS connection
    if self._nc:
        try:
            await self._nc.close()
        except Exception:
            pass
    
    logger.info("Event publisher shutdown complete")
```

## Batch Status Monitoring

```python
def get_batch_status(self) -> Dict[str, Any]:
    """Get current batch status for debugging"""
    if not self._current_batch:
        return {"status": "no_batch", "events": 0}
    
    batch_age = time.time() - self._current_batch.created_at
    
    return {
        "status": "active",
        "events": len(self._current_batch.events),
        "age_seconds": batch_age,
        "batch_timeout": self.batch_timeout,
        "batch_size": self.batch_size,
        "will_publish_on_timeout": batch_age >= self.batch_timeout,
        "will_publish_on_size": len(self._current_batch.events) >= self.batch_size
    }
```

