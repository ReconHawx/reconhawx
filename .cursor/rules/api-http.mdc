### Import Endpoint Error Handling

```python
@router.post("/subdomain/import", response_model=Dict[str, Any])
async def import_domains(
    request: DomainImportRequest,
    current_user: UserResponse = Depends(get_current_user_from_middleware)
):
    try:
        # Validation
        if request.validate_domains:
            invalid_domains = validate_domain_names(request.domains)
            if invalid_domains:
                raise HTTPException(
                    status_code=400,
                    detail=f"Invalid domain names: {', '.join(invalid_domains[:10])}"
                )
        
        # Authorization check
        allowed_domains = filter_by_program_access(request.domains, current_user)
        if not allowed_domains:
            raise HTTPException(
                status_code=403,
                detail="No domains to import - all belong to unauthorized programs"
            )
        
        # Process domains
        imported_count = 0
        errors = []
        
        for domain_data in allowed_domains:
            try:
                domain_id, action, event_data = await repository.create_or_update(domain_data)
                if domain_id:
                    imported_count += 1
            except Exception as e:
                errors.append(f"Error processing {domain_data.name}: {str(e)}")
        
        # Return appropriate response based on results
        if errors and imported_count == 0:
            return {
                "status": "error",
                "message": "Import failed: no domains were processed",
                "data": {"errors": errors[:10]}
            }
        elif errors:
            return {
                "status": "partial_success",
                "message": f"Import completed: {imported_count} processed ({len(errors)} errors)",
                "data": {"processed_count": imported_count, "errors": errors[:10]}
            }
        else:
            return {
                "status": "success",
                "message": f"Import completed: {imported_count} processed",
                "data": {"processed_count": imported_count}
            }
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error in domain import: {str(e)}")
        raise HTTPException(
            status_code=500,
            detail=f"Error importing domains: {str(e)}"
        )
```

### Batch Delete Error Handling

```python
@router.delete("/subdomain/batch", response_model=Dict[str, Any])
