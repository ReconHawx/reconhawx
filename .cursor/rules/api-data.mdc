## Create or Update Pattern

### Standard Implementation

```python
@staticmethod
async def create_or_update_subdomain(subdomain_data: Dict[str, Any]) -> tuple[str, str, Optional[Dict[str, Any]]]:
    """Create or update subdomain.
    Returns (subdomain_id, action, event_data) where:
    - action is 'created', 'updated', 'skipped', or 'out_of_scope'
    - event_data contains rich payload for unified processor
    """
    async with get_db_session() as db:
        try:
            # Find program
            program = db.query(Program).filter(
                Program.name == subdomain_data.get('program_name')
            ).first()
            if not program:
                raise ValueError(f"Program '{subdomain_data.get('program_name')}' not found")
            
            # Scope check
            hostname = subdomain_data.get('name')
            if not await ProgramRepository.is_domain_in_scope(hostname, program.name):
                return "", "out_of_scope", None
            
            # Check if exists
            existing = db.query(Subdomain).filter(
                and_(
                    Subdomain.name == subdomain_data.get('name'),
                    Subdomain.program_id == program.id
                )
            ).first()
            
            if existing:
                # Track meaningful changes
                meaningful_changes = []
                
                if 'is_wildcard' in subdomain_data and subdomain_data.get('is_wildcard') != existing.is_wildcard:
                    existing.is_wildcard = subdomain_data.get('is_wildcard')
                    meaningful_changes.append('is_wildcard')
                
                if 'cname_record' in subdomain_data and subdomain_data.get('cname_record') != existing.cname_record:
                    existing.cname_record = subdomain_data.get('cname_record')
                    meaningful_changes.append('cname_record')
                
                # Handle IP relationships
                if 'ip' in subdomain_data and isinstance(subdomain_data['ip'], list):
                    for ip_address in subdomain_data['ip']:
                        # Find or create IP, create relationship
                        # ...
                        meaningful_changes.append('ip_relationship')
                
                if meaningful_changes:
                    existing.updated_at = datetime.now(timezone.utc)
                    db.commit()
                    
                    event_data = {
                        "event": "asset.updated",
                        "asset_type": "subdomain",
                        "record_id": str(existing.id),
                        "name": subdomain_data.get('name'),
                        "program_name": subdomain_data.get('program_name'),
                        # ... additional event data
                    }
                    return str(existing.id), "updated", event_data
                else:
                    return str(existing.id), "skipped", None
            
            else:
                # Create new
                subdomain = Subdomain(
                    name=subdomain_data.get('name'),
                    apex_domain_id=apex_domain.id,
                    is_wildcard=subdomain_data.get('is_wildcard', False),
                    program_id=program.id,
                    cname_record=subdomain_data.get('cname_record'),
                )
                db.add(subdomain)
                db.commit()
                db.refresh(subdomain)
                
                # Handle IP relationships
                # ...
                
                event_data = {
                    "event": "asset.created",
                    "asset_type": "subdomain",
                    "record_id": str(subdomain.id),
                    "name": subdomain_data.get('name'),
                    "program_name": subdomain_data.get('program_name'),
                    # ... additional event data
                }
                return str(subdomain.id), "created", event_data
            
        except Exception as e:
            db.rollback()
            logger.error(f"Error creating/updating subdomain: {str(e)}")
            raise
```

## Batch Operations

### Batch Delete

```python
@staticmethod
async def delete_subdomains_batch(subdomain_ids: List[str]) -> Dict[str, Any]:
    """Delete multiple subdomains by their IDs"""
    async with get_db_session() as db:
        try:
            deleted_count = 0
            not_found_count = 0
            error_count = 0
            errors = []
            
            for subdomain_id in subdomain_ids:
                try:
                    # Validate ID
                    if subdomain_id is None or subdomain_id == "":
                        error_count += 1
                        errors.append(f"Invalid subdomain ID: {subdomain_id}")
                        continue
                    
                    # Convert to UUID
                    try:
                        subdomain_uuid = UUID(subdomain_id)
                    except ValueError as e:
                        error_count += 1
                        errors.append(f"Invalid UUID format: {subdomain_id}")
                        continue
                    
                    # Find and delete
                    subdomain = db.query(Subdomain).filter(
                        Subdomain.id == subdomain_uuid
                    ).first()
                    
                    if not subdomain:
                        not_found_count += 1
                        continue
                    
                    db.delete(subdomain)
                    deleted_count += 1
                    
                except Exception as e:
                    error_count += 1
                    errors.append(f"Error deleting {subdomain_id}: {str(e)}")
            
            db.commit()
            
            return {
                "deleted_count": deleted_count,
                "not_found_count": not_found_count,
                "error_count": error_count,
                "errors": errors
            }
            
        except Exception as e:
            db.rollback()
            logger.error(f"Error in batch delete: {str(e)}")
            raise
```

### Chunked Bulk Insert

```python
@staticmethod
async def bulk_create_subdomains(subdomains: List[Dict[str, Any]], chunk_size: int = 1000) -> int:
    """Bulk create subdomains in chunks"""
    total_created = 0
    
    for i in range(0, len(subdomains), chunk_size):
        chunk = subdomains[i:i + chunk_size]
        async with get_batch_db_session() as db:
            db.bulk_insert_mappings(Subdomain, chunk)
            db.commit()
            total_created += len(chunk)
    
    return total_created
```

## Distinct Values for Faceted Filtering

```python
@staticmethod
async def get_distinct_values(field_name: str, filter_data: Optional[Dict[str, Any]] = None) -> List[str]:
    """Get distinct values for a specified field"""
    from sqlalchemy import func
    
    async with get_db_session() as db:
        query = db.query(Subdomain).join(Program, Program.id == Subdomain.program_id)
        
        # Apply program filter if provided
        if filter_data and filter_data.get('program_name'):
            program_value = filter_data['program_name']
            if isinstance(program_value, list):
                if len(program_value) == 0:
                    return []
                query = query.filter(Program.name.in_(program_value))
            else:
                query = query.filter(Program.name == program_value)
        
        # Get distinct values based on field name
        if field_name == 'name':
            values = query.with_entities(Subdomain.name).distinct().all()
        elif field_name == 'apex_domain':
            values = query.join(ApexDomain).with_entities(ApexDomain.name).distinct().all()
        elif field_name == 'wildcard_types':
            # For array fields, unnest the arrays
            values = query.with_entities(func.unnest(Subdomain.wildcard_types)).distinct().all()
        else:
            raise ValueError(f"Unsupported field '{field_name}'")
        
        return [str(v[0]) for v in values if v[0] is not None]
```

## Data Conversion

### SQLAlchemy to Dict

```python
def _subdomain_to_dict(subdomain: Subdomain, db=None) -> Dict[str, Any]:
    """Convert SQLAlchemy model to dictionary"""
    # Get associated IPs if db session provided
    ip_addresses = []
    if db:
        ip_query = db.query(IP.ip_address).join(
            SubdomainIP, IP.id == SubdomainIP.ip_id
        ).filter(SubdomainIP.subdomain_id == subdomain.id).all()
        ip_addresses = [ip[0] for ip in ip_query]
    
    return {
        "id": str(subdomain.id),
        "name": subdomain.name,
        "program_name": subdomain.program.name if subdomain.program else None,
        "apex_domain": subdomain.apex_domain.name if subdomain.apex_domain else None,
        "is_wildcard": subdomain.is_wildcard,
        "cname_record": subdomain.cname_record,
        "ip": ip_addresses,
        "notes": subdomain.notes,
        "created_at": subdomain.created_at.isoformat() if subdomain.created_at else None,
        "updated_at": subdomain.updated_at.isoformat() if subdomain.updated_at else None,
    }
```

## Error Handling

### Let Exceptions Propagate

Repositories should let exceptions propagate to route handlers:

```python
@staticmethod
async def create_subdomain(subdomain_data: Dict[str, Any]) -> str:
    """Create subdomain - let exceptions propagate"""
    async with get_db_session() as db:
        try:
            subdomain = Subdomain(**subdomain_data)
            db.add(subdomain)
            db.commit()
            db.refresh(subdomain)
            return str(subdomain.id)
        except IntegrityError as e:
            # Convert to ValueError for route handler
            raise ValueError(f"Subdomain already exists: {e}")
```

### Handling Not Found

```python
@staticmethod
async def get_subdomain(subdomain_id: str) -> Optional[Dict[str, Any]]:
    """Return None if not found, let route handle 404"""
    async with get_db_session() as db:
        subdomain = db.query(Subdomain).filter(Subdomain.id == subdomain_id).first()
        if not subdomain:
            return None  # Route will handle 404
        return _subdomain_to_dict(subdomain)
```

## Best Practices

### DO:
- ✅ Use static methods for stateless operations
- ✅ Inherit from `ProgramAccessMixin` for program-scoped data
- ✅ Use `apply_program_access_filter()` for queries
- ✅ Return dictionaries or Pydantic models, not SQLAlchemy objects
- ✅ Use `get_batch_db_session()` for bulk operations
- ✅ Return `(id, action, event_data)` tuple from create_or_update methods
- ✅ Use keyword-only arguments (`*,`) for typed search methods
- ✅ Handle relationships with eager loading where appropriate
- ✅ Let exceptions propagate to route handlers

### DON'T:
- ❌ Store state in repository classes
- ❌ Return SQLAlchemy objects directly
- ❌ Skip program access filtering
- ❌ Use instance methods unless necessary
- ❌ Handle HTTP exceptions in repositories
- ❌ Create multiple database sessions unnecessarily
- ❌ Use positional arguments for complex search methods

