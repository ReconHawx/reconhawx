### Workflow

```python
class Workflow(BaseModel):
    name: str
    program_name: Optional[str] = None  # null = global workflow
    steps: List[Union[Step, WorkflowStep]]
    definition: Optional[WorkflowDefinition] = None
    variables: Optional[Dict[str, Any]] = {}
    inputs: Optional[Dict[str, InputDefinition]] = {}
    
    @model_validator(mode='after')
    def extract_definition_fields(self):
        """Extract fields from definition for easier access"""
        if self.definition:
            if not self.inputs:
                self.inputs = self.definition.inputs
            if not self.variables:
                self.variables = self.definition.variables
            if self.definition.steps:
                self.steps = self.definition.steps
        return self
```

### AssetStore

```python
class AssetStore:
    """In-memory storage for workflow step outputs"""
    
    def __init__(self):
        self.assets: Dict[str, Dict[str, List[Any]]] = {}
    
    def add_step_assets(self, step_name: str, asset_type: str, assets: List):
        """Store assets from a step"""
        if step_name not in self.assets:
            self.assets[step_name] = {}
        if asset_type not in self.assets[step_name]:
            self.assets[step_name][asset_type] = []
        self.assets[step_name][asset_type].extend(assets)
    
    def get_step_assets(self, step_name: str, asset_type: str = None):
        """Retrieve assets from a step"""
        if step_name not in self.assets:
            return {} if asset_type is None else []
        if asset_type is None:
            return self.assets[step_name]
        return self.assets[step_name].get(asset_type, [])
```

## Serialization Patterns

### Model Serialization

```python
# Pydantic v2 serialization
asset_dict = domain.model_dump(by_alias=True, exclude_none=True)

# For JSON (handles datetime)
asset_json = domain.model_dump(mode='json', by_alias=True)

# Custom to_dict (excludes None to prevent overwriting)
def to_dict(self):
    return self.model_dump(by_alias=True, exclude_none=True)
```

### Datetime Handling

```python
# In models/base.py
def serialize_datetime(dt: datetime) -> str:
    return dt.isoformat() if dt else None

# Model config
model_config = ConfigDict(
    json_encoders={ObjectId: str, datetime: serialize_datetime}
)
```

### Task Output to API

```python
# In DataAPIClient
def _convert_assets_to_dicts(self, assets: Dict[str, List]) -> Dict[str, List[Dict]]:
    """Convert Pydantic models to dicts for API submission"""
    converted = {}
    for asset_type, asset_list in assets.items():
        converted_list = []
        for asset in asset_list:
            if hasattr(asset, 'model_dump'):
                # Pydantic v2
                asset_dict = asset.model_dump(by_alias=True, exclude_none=True)
            elif hasattr(asset, 'to_dict'):
                asset_dict = asset.to_dict()
            elif isinstance(asset, dict):
                asset_dict = asset
            else:
                asset_dict = asset.__dict__.copy()
            converted_list.append(asset_dict)
        converted[asset_type] = converted_list
    return converted
```

## Best Practices

1. **Always lowercase domains**: `name=domain.lower()`
2. **Use sets for deduplication**: IP and Domain models support `__hash__` and `__eq__`
3. **Exclude None values**: Use `exclude_none=True` to prevent overwriting existing API data
4. **Handle datetime correctly**: Use `mode='json'` for JSON serialization
5. **Use aliases**: `Field(alias="typosquat_domain")` for API field mapping
6. **Validate early**: Pydantic validates on model creation
