## Component Classes (typosquat_components.py)

### VariationCacheManager

```python
class VariationCacheManager:
    """Redis-based caching of tested domain variations"""
    
    def __init__(self, redis_url=None, default_ttl=None):
        self.redis_url = redis_url or os.getenv('REDIS_URL', 'redis://redis:6379/0')
        self.default_ttl = default_ttl or int(os.getenv('TYPOSQUAT_CACHE_TTL', '2592000'))
        # 2592000 seconds = 30 days
    
    def _get_cache_key(self, variation_domain, original_domain, program_name):
        return f"typosquat:tested:{program_name}:{original_domain}:{variation_domain}"
    
    def mark_variation_as_tested(self, variation_domain, original_domain, program_name):
        """Mark a variation as tested (cached for TTL)"""
        cache_value = json.dumps({
            "tested_at": datetime.utcnow().isoformat(),
            "original_domain": original_domain,
            "variation_domain": variation_domain
        })
        self.redis_client.setex(cache_key, self.default_ttl, cache_value)
    
    def filter_untested_variations(self, variations, original_domain, program_name):
        """Filter out variations that are already cached"""
        tested = self.get_tested_variations(original_domain, program_name)
        return {d: f for d, f in variations.items() if d not in tested}
```

### ApiClient

```python
class ApiClient:
    """API communication for typosquat detection"""
    
    def get_already_tested_domains(self, original_domain=None, program_name=""):
        """Get domains that already exist in the API (historical deduplication)"""
        response = requests.post(
            f"{self.data_api_url}/findings/typosquat/search",
            json={
                "program": program_name,
                "original_domain": original_domain,
                "page_size": 100
            },
            headers=self.headers
        )
        
        tested_domains = set()
        for item in response.json().get("items", []):
            tested_domains.add(item.get("typo_domain"))
        return tested_domains
```

