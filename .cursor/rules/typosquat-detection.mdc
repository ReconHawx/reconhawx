### BuiltInDomainAnalyzer

```python
class BuiltInDomainAnalyzer:
    def analyze_domain(self, domain, active_checks=False, geoip_checks=False):
        info = {
            "domain": domain,
            "registered": False,
            "dns_a": [],
            "dns_mx": [],
            "whois": {},
            "ssl": {},
            "http": {},
            "geoip": {},
            "is_wildcard": False,
            "wildcard_types": []
        }
        
        # 1. DNS Resolution with Wildcard Detection
        dns_results = self._resolve_domain_with_wildcard_detection(domain)
        if dns_results["has_records"]:
            info["registered"] = True
            info["dns_a"] = dns_results["a_records"]
            info["is_wildcard"] = dns_results["is_wildcard"]
            
            # 2. Active HTTP Checks (if enabled)
            if active_checks:
                typosquat_urls = self._check_http_with_httpx(domain)
            
            # 3. GeoIP Lookup (if enabled)
            if geoip_checks and info["dns_a"]:
                info["geoip"] = self._check_geoip(info["dns_a"][0])
        
        # 4. WHOIS Lookup (for root domains)
        if not self._is_subdomain(domain):
            info["whois"] = self._check_whois(domain)
            if info["whois"]:
                info["registered"] = True
        
        return info, typosquat_urls
```

### HTTP Probing with httpx

```python
def _check_http_with_httpx(self, domain):
    command = (
        f"printf '{domain}' | httpx "
        "-fr "                    # Follow redirects
        "-maxr 10 "               # Max redirects
        "-include-chain "         # Include redirect chain
        "-silent "
        "-status-code "
        "-content-length "
        "-tech-detect "           # Technology detection
        "-threads 50 "
        "-json "
        "-tls-grab "              # TLS certificate info
        "-pipeline "              # HTTP pipelining
        "-http2 "
        "-ip "                    # Resolve IP
        "-cname "                 # CNAME records
        "-asn "                   # ASN info
        "-favicon "               # Favicon hash
        "-hash sha256 "           # Body hash
        "-p 80-99,443-449,11443,8443-8449,9000-9003,8080-8089,8801-8810,3000,5000"
    )
```

