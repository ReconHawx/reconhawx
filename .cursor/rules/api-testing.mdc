## Testing Services

### Mocking External APIs

```python
import pytest
from unittest.mock import AsyncMock, patch
import httpx

@patch("services.hackerone_service.httpx.AsyncClient")
@pytest.mark.asyncio
async def test_hackerone_service_fetch_program(mock_client):
    """Test fetching program from HackerOne API"""
    # Mock response
    mock_response = AsyncMock()
    mock_response.json.return_value = {"data": {"attributes": {"name": "Test Program"}}}
    mock_response.raise_for_status = AsyncMock()
    
    mock_client.return_value.__aenter__.return_value.get.return_value = mock_response
    
    service = HackerOneService(api_token="test-token")
    result = await service.fetch_program_details("test-program")
    
    assert result["data"]["attributes"]["name"] == "Test Program"

@patch("services.hackerone_service.httpx.AsyncClient")
@pytest.mark.asyncio
async def test_hackerone_service_handles_401(mock_client):
    """Test handling of 401 Unauthorized"""
    mock_response = AsyncMock()
    mock_response.status_code = 401
    mock_response.raise_for_status.side_effect = httpx.HTTPStatusError(
        "Unauthorized", request=None, response=mock_response
    )
    
    mock_client.return_value.__aenter__.return_value.get.return_value = mock_response
    
    service = HackerOneService(api_token="invalid-token")
    
    with pytest.raises(ValueError, match="Invalid HackerOne API token"):
        await service.fetch_program_details("test-program")
```

