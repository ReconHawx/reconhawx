```

## Thread Pool Pattern for Blocking Operations

Kubernetes operations are blocking and should run in a thread pool:

```python
from concurrent.futures import ThreadPoolExecutor

# Create a thread pool executor for running blocking Kubernetes operations
thread_pool = ThreadPoolExecutor(max_workers=4)

@router.post("/executions/{workflow_id}/stop")
async def stop_workflow_execution(workflow_id: str):
    """Stop a running workflow execution"""
    
    # Update status immediately
    await workflow_repository.create_workflow_log({
        "result": "stopping",
        "execution_id": workflow_id
    })
    
    # Run K8s cleanup in background thread
    def run_k8s_cleanup():
        try:
            stop_results = k8s_service.stop_workflow(workflow_id)
            
            # Update status after cleanup (from background thread)
            loop = asyncio.get_event_loop()
            future = asyncio.run_coroutine_threadsafe(
                workflow_repository.create_workflow_log({
                    "result": "stopped",
                    "execution_id": workflow_id,
                    "stop_results": stop_results
                }), 
                loop
            )
            future.result()
        except Exception as e:
            logger.error(f"Cleanup failed: {e}")
    
    # Submit to thread pool (non-blocking)
    thread_pool.submit(run_k8s_cleanup)
    
    return {"status": "stopping", "workflow_id": workflow_id}
```

## Workflow Route Patterns

### Workflow Definition CRUD

```python
@router.get("/definitions", response_model=WorkflowListResponse)
async def get_workflow_definitions(
    program_name: Optional[str] = Query(None),
    current_user: UserResponse = Depends(get_current_user_from_middleware)
):
    """Get all saved workflow definitions"""
    workflows_data = await workflow_definition_repository.get_workflow_definitions(program_name)
    
    # Filter based on user permissions
    accessible_workflows = []
    for workflow_data in workflows_data:
        workflow_program = workflow_data.get("program_name")
        
        # Global workflows are accessible to everyone
        if not workflow_program:
            accessible_workflows.append(workflow_data)
            continue
        
        # Check program permission for program-specific workflows
        if check_program_permission(current_user, workflow_program, "analyst"):
            accessible_workflows.append(workflow_data)
    
    return WorkflowListResponse(workflows=accessible_workflows, count=len(accessible_workflows))
```

### Workflow Execution with Retry

```python
@router.post("/run", response_model=WorkflowCreateResponse)
async def run_workflow(
    workflow_request: WorkflowRequest,
    priority: str = Query("normal", description="Priority: low, normal, high, critical"),
    current_user: UserResponse = Depends(get_current_user_from_middleware)
):
    """Execute a workflow"""
    
    # Check program permission
    if workflow_request.program_name:
        if not check_program_permission(current_user, workflow_request.program_name, "manager"):
            raise HTTPException(status_code=403, detail="Manager access required")
    
    execution_id = str(uuid.uuid4())
    
    workflow_data = {
        "workflow_id": workflow_request.workflow_definition_id,
        "execution_id": execution_id,
        "program_name": workflow_request.program_name,
        "name": workflow_request.workflow_name,
        "priority": priority,
        "steps": [step.dict(exclude_none=False) for step in workflow_request.steps]
    }
    
    # Retry logic for K8s job creation
    max_retries = 3
    for attempt in range(max_retries):
        try:
            await k8s_service.create_runner_job(workflow_data)
            break
        except Exception as e:
            if attempt == max_retries - 1:
                raise HTTPException(status_code=500, detail=f"Failed after {max_retries} attempts")
            time.sleep(1)
    
    return WorkflowCreateResponse(
        workflow_id=execution_id,
        status="started",
        status_url=create_status_url(request, "workflow", execution_id)
    )
```

## Queue Management Endpoints

### Queue Status

```python
@router.get("/queue/status", response_model=QueueCapacityResponse)
async def get_queue_status():
    """Get current queue status and capacity"""
    capacity_info = k8s_service.check_queue_capacity()
    return QueueCapacityResponse(**capacity_info)

# Response includes:
# - queue_length: Current number of workloads
# - has_capacity: Boolean indicating if queue can accept more
# - estimated_wait_time: Rough estimate in minutes
# - queue_name: Name of the Kueue queue
```

### Workload Priority Update

```python
class PriorityUpdateRequest(BaseModel):
    priority: str = Field(..., description="Priority: low, normal, high, critical")

@router.put("/queue/workloads/{execution_id}/priority")
async def update_workload_priority(
    execution_id: str,
    priority_request: PriorityUpdateRequest
):
    """Update workload priority in queue"""
    valid_priorities = ['low', 'normal', 'high', 'critical']
    if priority_request.priority not in valid_priorities:
        raise HTTPException(status_code=400, detail=f"Invalid priority")
    
    success = k8s_service.update_workload_priority(execution_id, priority_request.priority)
    if not success:
        raise HTTPException(status_code=404, detail="Workload not found")
    
    return {"status": "success", "priority": priority_request.priority}
```

## Environment Variables

Key environment variables for workflow execution:

| Variable | Default | Description |
|----------|---------|-------------|
| `KUBERNETES_NAMESPACE` | `default` | Namespace for K8s resources |
| `KUEUE_ENABLED` | `true` | Enable Kueue integration |
| `KUEUE_WORKFLOW_QUEUE` | `recon-runner-queue` | Local queue name |
| `KUEUE_CLUSTER_QUEUE` | `cluster-queue` | Cluster queue name |
| `WORKFLOW_CPU_REQUEST` | `500m` | CPU request |
| `WORKFLOW_CPU_LIMIT` | `2000m` | CPU limit |
| `WORKFLOW_MEMORY_REQUEST` | `1Gi` | Memory request |
| `WORKFLOW_MEMORY_LIMIT` | `4Gi` | Memory limit |
| `RUNNER_IMAGE` | `runner:latest` | Runner container image |
| `WORKER_IMAGE` | `worker:latest` | Worker container image |
| `JOB_TTL_SECONDS` | `300` | TTL after job completion |
| `INTERNAL_SERVICE_API_KEY` | - | API key for internal auth |

