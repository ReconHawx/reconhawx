## External Service Integrations

### HackerOne Service Pattern

```python
import httpx
import logging

logger = logging.getLogger(__name__)

class HackerOneService:
    def __init__(self, api_token: str):
        self.api_token = api_token
        self.base_url = "https://api.hackerone.com/v1"
        self.timeout = 30.0
    
    async def fetch_program_details(self, program_handle: str) -> Dict[str, Any]:
        """Fetch program details from HackerOne API"""
        headers = {
            "Authorization": f"Bearer {self.api_token}",
            "Accept": "application/json"
        }
        
        try:
            async with httpx.AsyncClient(timeout=self.timeout) as client:
                response = await client.get(
                    f"{self.base_url}/programs/{program_handle}",
                    headers=headers
                )
                response.raise_for_status()
                return response.json()
        
        except httpx.HTTPStatusError as e:
            if e.response.status_code == 401:
                raise ValueError("Invalid HackerOne API token")
            elif e.response.status_code == 404:
                raise ValueError(f"Program '{program_handle}' not found")
            elif e.response.status_code == 429:
                raise ValueError("Rate limit exceeded")
            else:
                raise ValueError(f"HackerOne API error: {e.response.status_code}")
        
        except httpx.TimeoutException:
            raise ValueError("Request to HackerOne API timed out")
        
        except Exception as e:
            logger.exception(f"Unexpected error: {e}")
            raise ValueError(f"Failed to fetch program: {str(e)}")
