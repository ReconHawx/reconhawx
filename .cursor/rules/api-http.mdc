                detail=f"Manager access required for program {request.program_name}"
            )
        
        # Call repository
        asset_id, action, event_data = await repository.create_or_update_asset(request.model_dump())
        
        return {
            "status": "success",
            "data": {"id": asset_id, **request.model_dump()}
        }
    
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error creating asset: {e}")
        raise HTTPException(status_code=500, detail=str(e))
