# API Repository Patterns

## Repository Structure

Repositories are the data access layer, abstracting database operations from business logic.

### Base Pattern

```python
from typing import Dict, Any, Optional, List, Union
from db import get_db_session
from utils.query_filters import ProgramAccessMixin
from models.postgres import Program, Subdomain
import logging

logger = logging.getLogger(__name__)

class SubdomainAssetsRepository(ProgramAccessMixin):
    """PostgreSQL repository for subdomain assets"""
    
    @staticmethod
    async def get_subdomain(subdomain_id: str) -> Optional[Dict[str, Any]]:
        """Get a single subdomain by ID"""
        async with get_db_session() as db:
            subdomain = db.query(Subdomain).filter(Subdomain.id == subdomain_id).first()
            if not subdomain:
                return None
            return _subdomain_to_dict(subdomain)
    
    @staticmethod
    async def create_or_update_subdomain(subdomain_data: Dict[str, Any]) -> tuple[str, str, Optional[Dict[str, Any]]]:
        """Create or update a subdomain.
        Returns (subdomain_id, action, event_data) where action is 'created', 'updated', 'skipped', or 'out_of_scope'
        """
        async with get_db_session() as db:
            # Implementation...
            pass
```

## Key Principles

1. **Static Methods**: Repositories use static methods for stateless operations
2. **ProgramAccessMixin**: Inherit from `ProgramAccessMixin` for program-scoped data
3. **Session Management**: Use `get_db_session()` or `get_batch_db_session()` for database access
4. **Error Handling**: Let exceptions propagate (handled at route level)
5. **Return Types**: Return dictionaries or Pydantic models, not SQLAlchemy objects
6. **Create/Update Pattern**: Return `(id, action, event_data)` tuple for unified processing

## Program Access Control

### ProgramAccessMixin

All program-scoped repositories should inherit from `ProgramAccessMixin`:

```python
from utils.query_filters import ProgramAccessMixin, QueryFilterUtils

class SubdomainAssetsRepository(ProgramAccessMixin):
    """Repository with program access control"""
    
    @staticmethod
    async def get_subdomains(query_filter: Dict[str, Any]) -> List[Dict[str, Any]]:
        async with get_db_session() as db:
            # Start with base query
            base_query = db.query(Subdomain)
            
            # Apply program access filtering
            filtered_query = SubdomainAssetsRepository.apply_program_access_filter(
                base_query, query_filter, Program
            )
            
            results = filtered_query.all()
            return [_subdomain_to_dict(r) for r in results]
```

**How It Works**:
- `filter_by_user_programs()` in route adds `program_name: {"$in": [...]}` to filter
- `apply_program_access_filter()` converts this to SQLAlchemy query
- Empty `$in` list returns no results (no access)

## Query Filtering

### MongoDB-Style Filters

The API supports MongoDB-style query filters for consistency:

```python
# Simple equality
filter = {"program_name": "example"}

# $in operator
filter = {"program_name": {"$in": ["program1", "program2"]}}

# $regex operator (case-insensitive)
filter = {"name": {"$regex": "example", "$options": "i"}}

# $and operator
filter = {
    "$and": [
        {"program_name": "example"},
        {"resolved": True}
    ]
}

# $or operator
filter = {
    "$or": [
        {"status": "active"},
        {"status": "pending"}
    ]
}
```

### Applying Filters

```python
from utils.query_filters import QueryFilterUtils

@staticmethod
async def get_subdomains(query_filter: Dict[str, Any]) -> List[Dict[str, Any]]:
    async with get_db_session() as db:
        base_query = db.query(Subdomain)
        conditions = []
        
        # Apply program filter
        base_query, program_conditions = QueryFilterUtils.apply_program_filter(
            base_query, query_filter, Program
        )
        conditions.extend(program_conditions)
        
        # Apply regex filters
        if "name" in query_filter:
            conditions.append(
                QueryFilterUtils.apply_regex_filter(Subdomain.name, query_filter["name"])
            )
        
        # Apply boolean filters
        if "resolved" in query_filter:
            conditions.append(Subdomain.resolved == query_filter["resolved"])
        
        # Apply all conditions
        if conditions:
            base_query = base_query.filter(and_(*conditions))
        
        results = base_query.all()
        return [_subdomain_to_dict(r) for r in results]
```

## Typed Search Pattern

### search_*_typed Methods

For typed search endpoints, use keyword-only arguments:

```python
@staticmethod
async def search_subdomains_typed(
    *,  # Force keyword arguments
    search: Optional[str] = None,
    exact_match: Optional[str] = None,
    apex_domain: Optional[Union[str, List[str]]] = None,
    wildcard: Optional[bool] = None,
    has_ips: Optional[bool] = None,
    ip: Optional[Union[str, List[str]]] = None,
    has_cname: Optional[bool] = None,
    cname_contains: Optional[str] = None,
    programs: Optional[List[str]] = None,
    sort_by: str = "updated_at",
    sort_dir: str = "desc",
    limit: int = 25,
    skip: int = 0,
) -> Dict[str, Any]:
    """
    Execute a strongly-typed subdomain search optimized for PostgreSQL.
    
    Returns a dict with keys: items (list[dict]), total_count (int)
    """
    async with get_db_session() as db:
        # Build aggregation columns for IP data
        count_ip_col = func.count(func.distinct(IP.id))
        ip_array_col = func.array_remove(
            func.array_agg(func.distinct(func.host(IP.ip_address))),
            None,
        )
        
        # Build base query with joins
        base_query = (
            db.query(
                Subdomain.id.label("id"),
                Subdomain.name.label("name"),
                Program.name.label("program_name"),
                ApexDomain.name.label("apex_domain"),
                Subdomain.is_wildcard.label("is_wildcard"),
                Subdomain.cname_record.label("cname_record"),
                Subdomain.created_at.label("created_at"),
                Subdomain.updated_at.label("updated_at"),
                ip_array_col.label("ip"),
                count_ip_col.label("ip_count"),
            )
            .select_from(Subdomain)
            .join(Program, Program.id == Subdomain.program_id)
            .join(ApexDomain, ApexDomain.id == Subdomain.apex_domain_id)
            .outerjoin(SubdomainIP, Subdomain.id == SubdomainIP.subdomain_id)
            .outerjoin(IP, IP.id == SubdomainIP.ip_id)
        )
        
        # Apply filters
        if programs is not None and len(programs) > 0:
            base_query = base_query.filter(Program.name.in_(programs))
        
        if search:
            base_query = base_query.filter(Subdomain.name.ilike(f"%{search}%"))
        
        if exact_match:
            base_query = base_query.filter(Subdomain.name == exact_match)
        
        if apex_domain:
            if isinstance(apex_domain, list):
                base_query = base_query.filter(ApexDomain.name.in_(apex_domain))
            else:
                base_query = base_query.filter(ApexDomain.name == apex_domain)
        
        if wildcard is not None:
            base_query = base_query.filter(Subdomain.is_wildcard == bool(wildcard))
        
        if has_cname is not None:
            if has_cname:
                base_query = base_query.filter(Subdomain.cname_record.isnot(None))
            else:
                base_query = base_query.filter(Subdomain.cname_record.is_(None))
        
        if cname_contains:
            base_query = base_query.filter(Subdomain.cname_record.ilike(f"%{cname_contains}%"))
        
        if ip is not None:
            if isinstance(ip, list):
                if len(ip) > 0:
                    base_query = base_query.filter(func.host(IP.ip_address).in_(ip))
            elif isinstance(ip, str) and ip.strip():
                base_query = base_query.filter(func.host(IP.ip_address) == ip.strip())
        
        # HAVING clause for has_ips filter
        _apply_has_ips_having = None
        if has_ips is not None:
            if has_ips:
                _apply_has_ips_having = func.count(func.distinct(IP.id)) > 0
            else:
                _apply_has_ips_having = func.count(func.distinct(IP.id)) == 0
        
        # Grouping for aggregation
        base_query = base_query.group_by(
            Subdomain.id, Subdomain.name, Program.name, ApexDomain.name,
            Subdomain.is_wildcard, Subdomain.cname_record,
            Subdomain.created_at, Subdomain.updated_at,
        )
        
        if _apply_has_ips_having is not None:
            base_query = base_query.having(_apply_has_ips_having)
        
        # Sorting
        direction_func = asc if sort_dir == "asc" else desc
        sort_column = getattr(Subdomain, sort_by, Subdomain.updated_at)
        base_query = base_query.order_by(direction_func(sort_column))
        
        # Pagination
        base_query = base_query.offset(skip).limit(limit)
        
        # Execute
        rows = base_query.all()
        
        items = []
        for r in rows:
            items.append({
                "id": str(r.id),
                "name": r.name,
                "program_name": r.program_name,
                "apex_domain": r.apex_domain,
                "is_wildcard": r.is_wildcard,
                "cname_record": r.cname_record,
                "created_at": r.created_at.isoformat() if r.created_at else None,
                "updated_at": r.updated_at.isoformat() if r.updated_at else None,
                "ip": list(r.ip) if r.ip else [],
                "ip_count": int(r.ip_count or 0),
            })
        
        # Count query (separate for performance)
        # ... similar filter logic for count query
        total_count = db.query(func.count()).select_from(count_subquery).scalar() or 0
        
        return {"items": items, "total_count": int(total_count)}
```

