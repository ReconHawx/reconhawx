# API Testing Patterns

## Testing Routes

### Testing with Authentication

```python
import pytest
from fastapi.testclient import TestClient
from unittest.mock import Mock, patch, AsyncMock
from datetime import datetime

@pytest.fixture
def client():
    from main import app
    return TestClient(app)

@pytest.fixture
def mock_superuser():
    """Mock superuser with full access"""
    return UserResponse(
        id="test-superuser-id",
        username="superuser",
        email="super@example.com",
        is_active=True,
        is_superuser=True,
        is_admin=True,
        program_permissions={},
        roles=["admin"],
        created_at=datetime.utcnow(),
        updated_at=datetime.utcnow()
    )

@pytest.fixture
def mock_regular_user():
    """Mock regular user with limited program access"""
    return UserResponse(
        id="test-user-id",
        username="testuser",
        email="test@example.com",
        is_active=True,
        is_superuser=False,
        is_admin=False,
        program_permissions={"program1": "analyst", "program2": "manager"},
        roles=[],
        created_at=datetime.utcnow(),
        updated_at=datetime.utcnow()
    )

@pytest.fixture
def mock_user_no_access():
    """Mock user with no program access"""
    return UserResponse(
        id="test-no-access-id",
        username="noaccess",
        email="noaccess@example.com",
        is_active=True,
        is_superuser=False,
        is_admin=False,
        program_permissions={},
        roles=[],
        created_at=datetime.utcnow(),
        updated_at=datetime.utcnow()
    )

@patch("auth.dependencies.get_current_user_from_middleware")
def test_create_asset_as_superuser(mock_get_user, client, mock_superuser):
    """Test superuser can create assets in any program"""
    mock_get_user.return_value = mock_superuser
    
    response = client.post(
        "/assets/subdomain/import",
        json={
            "domains": [{"name": "example.com", "program_name": "any-program"}],
            "validate_domains": True
        }
    )
    
    assert response.status_code == 200
    assert response.json()["status"] == "success"
```

## Testing Program Access Filtering

### Testing get_user_accessible_programs

```python
from auth.dependencies import get_user_accessible_programs

def test_superuser_has_no_restrictions(mock_superuser):
    """Superuser returns empty list (no restrictions)"""
    accessible = get_user_accessible_programs(mock_superuser)
    assert accessible == []

def test_regular_user_has_program_list(mock_regular_user):
    """Regular user returns their program list"""
    accessible = get_user_accessible_programs(mock_regular_user)
    assert set(accessible) == {"program1", "program2"}

def test_user_no_access_returns_empty(mock_user_no_access):
    """User with no permissions returns empty list (no access)"""
    accessible = get_user_accessible_programs(mock_user_no_access)
    assert accessible == []
```

### Testing filter_by_user_programs

```python
from auth.dependencies import filter_by_user_programs

def test_superuser_filter_unchanged(mock_superuser):
    """Superuser's filter is not modified"""
    base_filter = {"name": "example"}
    result = filter_by_user_programs(base_filter, mock_superuser)
    assert result == base_filter

def test_regular_user_filter_adds_programs(mock_regular_user):
    """Regular user gets program filter added"""
    base_filter = {"name": "example"}
    result = filter_by_user_programs(base_filter, mock_regular_user)
    
    assert "program_name" in result
    assert "$in" in result["program_name"]
    assert set(result["program_name"]["$in"]) == {"program1", "program2"}

def test_user_no_access_gets_empty_filter(mock_user_no_access):
    """User with no access gets empty $in filter (returns no results)"""
    base_filter = {"name": "example"}
    result = filter_by_user_programs(base_filter, mock_user_no_access)
    
    assert result == {"program_name": {"$in": []}}

def test_filter_intersects_with_requested(mock_regular_user):
    """Requested programs intersected with accessible"""
    base_filter = {"program_name": {"$in": ["program1", "program3"]}}
    result = filter_by_user_programs(base_filter, mock_regular_user)
    
    # Only program1 is accessible
    assert result["program_name"]["$in"] == ["program1"]
```

### Testing check_program_permission

```python
from auth.dependencies import check_program_permission

def test_superuser_has_all_permissions(mock_superuser):
    """Superuser has manager access to all programs"""
    assert check_program_permission(mock_superuser, "any-program", "analyst") is True
    assert check_program_permission(mock_superuser, "any-program", "manager") is True

def test_user_analyst_permission(mock_regular_user):
    """User with analyst permission can read"""
    assert check_program_permission(mock_regular_user, "program1", "analyst") is True
    assert check_program_permission(mock_regular_user, "program1", "manager") is False

def test_user_manager_permission(mock_regular_user):
    """User with manager permission can read and write"""
    assert check_program_permission(mock_regular_user, "program2", "analyst") is True
    assert check_program_permission(mock_regular_user, "program2", "manager") is True

def test_user_no_permission(mock_regular_user):
    """User has no access to non-assigned programs"""
    assert check_program_permission(mock_regular_user, "program3", "analyst") is False
    assert check_program_permission(mock_regular_user, "program3", "manager") is False
```

## Testing Typed Search Endpoints

### Testing Search with Program Filtering

```python
@pytest.fixture
def mock_search_result():
    return {
        "items": [
            {"id": "1", "name": "sub1.example.com", "program_name": "program1"},
            {"id": "2", "name": "sub2.example.com", "program_name": "program1"},
        ],
        "total_count": 2
    }

@patch("repository.SubdomainAssetsRepository.search_subdomains_typed")
@patch("auth.dependencies.get_current_user_from_middleware")
def test_search_as_superuser(mock_get_user, mock_search, client, mock_superuser, mock_search_result):
    """Superuser can search all programs"""
    mock_get_user.return_value = mock_superuser
    mock_search.return_value = mock_search_result
    
    response = client.post(
        "/assets/subdomain/search",
        json={"search": "example", "page": 1, "page_size": 25}
    )
    
    assert response.status_code == 200
    data = response.json()
    assert data["status"] == "success"
    assert len(data["items"]) == 2
    
    # Verify no program filter was applied (programs=None for superuser)
    call_args = mock_search.call_args
    assert call_args.kwargs.get("programs") is None

@patch("repository.SubdomainAssetsRepository.search_subdomains_typed")
@patch("auth.dependencies.get_current_user_from_middleware")
def test_search_as_regular_user(mock_get_user, mock_search, client, mock_regular_user, mock_search_result):
    """Regular user search is filtered to their programs"""
    mock_get_user.return_value = mock_regular_user
    mock_search.return_value = mock_search_result
    
    response = client.post(
        "/assets/subdomain/search",
        json={"search": "example", "page": 1, "page_size": 25}
    )
    
    assert response.status_code == 200
    
    # Verify program filter was applied
    call_args = mock_search.call_args
    assert set(call_args.kwargs.get("programs")) == {"program1", "program2"}

@patch("auth.dependencies.get_current_user_from_middleware")
def test_search_user_no_access_returns_empty(mock_get_user, client, mock_user_no_access):
    """User with no access gets empty results"""
    mock_get_user.return_value = mock_user_no_access
    
    response = client.post(
        "/assets/subdomain/search",
        json={"search": "example", "page": 1, "page_size": 25}
    )
    
    assert response.status_code == 200
    data = response.json()
    assert data["items"] == []
    assert data["pagination"]["total_items"] == 0
```

### Testing Pagination Response

```python
@patch("repository.SubdomainAssetsRepository.search_subdomains_typed")
@patch("auth.dependencies.get_current_user_from_middleware")
def test_search_pagination(mock_get_user, mock_search, client, mock_superuser):
    """Test pagination response format"""
    mock_get_user.return_value = mock_superuser
    mock_search.return_value = {"items": [], "total_count": 100}
    
    response = client.post(
        "/assets/subdomain/search",
        json={"page": 2, "page_size": 25}
    )
    
    assert response.status_code == 200
    data = response.json()
    
    assert "pagination" in data
    pagination = data["pagination"]
    assert pagination["total_items"] == 100
    assert pagination["total_pages"] == 4
    assert pagination["current_page"] == 2
    assert pagination["page_size"] == 25
    assert pagination["has_next"] is True
    assert pagination["has_previous"] is True
```

## Testing Repositories

### Testing with Mocked Database

```python
import pytest
from unittest.mock import AsyncMock, MagicMock, patch
from repository.subdomain_assets_repo import SubdomainAssetsRepository

@pytest.mark.asyncio
@patch("db.get_db_session")
async def test_get_domain_by_id(mock_session):
    """Test getting domain by ID"""
    # Setup mock
    mock_db = MagicMock()
    mock_subdomain = MagicMock()
    mock_subdomain.id = "test-id"
    mock_subdomain.name = "test.example.com"
    mock_subdomain.program.name = "program1"
    mock_subdomain.apex_domain.name = "example.com"
    mock_subdomain.created_at = datetime.utcnow()
    mock_subdomain.updated_at = datetime.utcnow()
    
    mock_db.query.return_value.join.return_value.filter.return_value.first.return_value = mock_subdomain
    mock_session.return_value.__aenter__.return_value = mock_db
    
    # Execute
    result = await SubdomainAssetsRepository.get_domain_by_id("test-id")
    
    # Verify
    assert result is not None
    assert result["id"] == "test-id"
    assert result["name"] == "test.example.com"
    assert result["program_name"] == "program1"

@pytest.mark.asyncio
@patch("db.get_db_session")
async def test_get_domain_by_id_not_found(mock_session):
    """Test getting non-existent domain returns None"""
    mock_db = MagicMock()
    mock_db.query.return_value.join.return_value.filter.return_value.first.return_value = None
    mock_session.return_value.__aenter__.return_value = mock_db
    
    result = await SubdomainAssetsRepository.get_domain_by_id("non-existent")
    
    assert result is None
```

